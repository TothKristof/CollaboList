// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  items     Item[]
  listUsers ListUser[]
}

model List {
  id       Int      @id @default(autoincrement())
  name     String
  category Category

  listUsers ListUser[]
  items     Item[]
}

model ListUser {
  userId Int
  listId Int
  role   ListRole @default(GUEST)

  user User @relation(fields: [userId], references: [id])
  list List @relation(fields: [listId], references: [id])

  @@id([userId, listId])
}

model Item {
  id       Int      @id @default(autoincrement())
  name     String
  price    Int
  category Category
  link     String
  imgLink  String?

  addDate         DateTime
  lastUpdatedDate DateTime

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  listId Int?
  list   List? @relation(fields: [listId], references: [id])
}

enum ListRole {
  OWNER
  COLLABORATOR
  GUEST
}

enum Category {
  Gaming
  Technology
  Personal
  HomeLiving
  Learning
  Style
  Wellness
  Hobbies
}
